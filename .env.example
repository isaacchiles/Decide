# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App ───────────────────────────────────────────────────────────────────────
# Your deployed domain (no trailing slash). Used for OG image URLs and share links.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ── AI ────────────────────────────────────────────────────────────────────────
# Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Images ────────────────────────────────────────────────────────────────────
# Pexels API key for fallback images when Wikipedia has no photo
# Get one free at https://www.pexels.com/api/
PEXELS_API_KEY=your-pexels-key

# ── Affiliate ─────────────────────────────────────────────────────────────────
# Amazon Associates tag (get approved at https://affiliate-program.amazon.com/)
# Must make ~3 qualifying sales within 180 days of approval to stay active.
# Amazon links may only appear on your site — not in emails or share text.
NEXT_PUBLIC_AMAZON_ASSOC_TAG=askhoot-20

# Shared secret for CPA network server-to-server postback validation (Phase 3)
# Generate a random string: openssl rand -hex 32
AFFILIATE_POSTBACK_SECRET=

# Phase 2 — add partner-specific env vars here as you get approved:
# NEXT_PUBLIC_CJ_TAG=your-cj-publisher-id
# NEXT_PUBLIC_IMPACT_TAG=your-impact-publisher-id
